<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meuevento.Views.Evento"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F4F7FC">

    <Grid RowDefinitions="*, Auto" Padding="24">

        <ScrollView>
            <VerticalStackLayout Spacing="30">

                <!-- Feedback Sucesso -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="15" Margin="0,40,0,10">
                    <Label Text="✓" 
                           FontSize="36" 
                           TextColor="#FFFFFF" 
                           BackgroundColor="#2A9D8F" 
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           HeightRequest="70" 
                           WidthRequest="70" 
                           FontAttributes="Bold">
                        <Label.Clip>
                            <EllipseGeometry RadiusX="35" RadiusY="35" Center="35,35"/>
                        </Label.Clip>
                    </Label>
                    <Label Text="Tudo Pronto!" FontSize="28" FontAttributes="Bold" TextColor="#2B2D42" HorizontalOptions="Center"/>
                    <Label Text="Seu evento foi configurado com sucesso." TextColor="#8D99AE" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Card de Resumo (Estilo Ticket) -->
                <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="White" Padding="0">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,15" Radius="30" Opacity="0.1"/>
                    </Border.Shadow>

                    <VerticalStackLayout>
                        <!-- Header Line do Card -->
                        <BoxView HeightRequest="8" BackgroundColor="#4A3AFF"/>

                        <VerticalStackLayout Padding="24" Spacing="20">
                            <Label Text="{Binding NomeEvento}" FontSize="26" FontAttributes="Bold" TextColor="#2B2D42"/>

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="📍" FontSize="18"/>
                                <Label Text="{Binding LocalEvento}" FontSize="15" TextColor="#6C757D" VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <BoxView HeightRequest="1" Color="#F0F0F0"/>

                            <!-- Grid de Informações com 4 Itens -->
                            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" RowSpacing="20">
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                    <Label Text="DATA" FontSize="11" FontAttributes="Bold" TextColor="#9BA3AF"/>
                                    <Label Text="{Binding DataCheckIn, StringFormat='{0:dd MMM}'}" FontSize="16" FontAttributes="Bold" TextColor="#2B2D42"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                    <Label Text="DURAÇÃO" FontSize="11" FontAttributes="Bold" TextColor="#9BA3AF"/>
                                    <Label Text="{Binding Estadia, StringFormat='{0} dias'}" FontSize="16" FontAttributes="Bold" TextColor="#2B2D42"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                    <Label Text="CONVIDADOS" FontSize="11" FontAttributes="Bold" TextColor="#9BA3AF"/>
                                    <Label Text="{Binding QntAdultos, StringFormat='{0} pessoas'}" FontSize="16" FontAttributes="Bold" TextColor="#2B2D42"/>
                                </VerticalStackLayout>

                                <!--Formato em Real Brasileiro (R$) -->
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                    <Label Text="CUSTO POR PESSOA" FontSize="11" FontAttributes="Bold" TextColor="#9BA3AF"/>
                                    <Label Text="{Binding CustoPorParticipante, StringFormat='R$ {0:N2}'}" FontSize="16" FontAttributes="Bold" TextColor="#2B2D42"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Rodapé do Card com Valor Total -->
                        <!-- Formato em Real Brasileiro (R$) -->
                        <Border StrokeShape="RoundRectangle 0,0,20,20" BackgroundColor="#F8F7FF" Padding="24,20" StrokeThickness="0">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="INVESTIMENTO TOTAL" VerticalOptions="Center" FontSize="12" FontAttributes="Bold" TextColor="#4A3AFF"/>
                                <Label Grid.Column="1" Text="{Binding ValorTotal, StringFormat='R$ {0:N2}'}" FontSize="24" FontAttributes="Bold" TextColor="#4A3AFF"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1" Text="EDITAR EVENTO" Clicked="Button_Clicked"
                BackgroundColor="Transparent" TextColor="#4A3AFF" FontAttributes="Bold"
                BorderColor="#4A3AFF" BorderWidth="2" HeightRequest="55" CornerRadius="28"/>
    </Grid>
</ContentPage>